{
  "name": "miauudio",
  "description": "Android-first offline ambient sound mixer.",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:native": "PUBLIC_APP_TARGET=native astro build",
    "preview": "astro preview",
    "astro": "astro",
    "android:assets": "capacitor-assets generate --android --assetPath public --iconBackgroundColor '#18181b' --iconBackgroundColorDark '#18181b' --splashBackgroundColor '#18181b' --splashBackgroundColorDark '#18181b'",
    "android:sync": "pnpm build:native && cap sync android",
    "android:open": "pnpm android:sync && cap open android",
    "android:run": "pnpm android:sync && cap run android --no-sync",
    "android:apk": "pnpm android:sync && ./android/gradlew -p android assembleDebug --console=plain",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "prepare": "husky install",
    "commit": "git-cz",
    "release": "standard-version --no-verify",
    "release:major": "pnpm run release --release-as major",
    "release:minor": "pnpm run release --release-as minor",
    "release:patch": "pnpm run release --release-as patch"
  },
  "dependencies": {
    "@astrojs/react": "5.0.6",
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@floating-ui/react": "0.26.0",
    "@formkit/auto-animate": "0.8.2",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.0.6",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-tooltip": "1.2.8",
    "@types/howler": "2.2.10",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vite-pwa/astro": "1.2.0",
    "astro": "6.4.8",
    "deepmerge": "4.3.1",
    "focus-trap-react": "10.2.3",
    "framer-motion": "10.16.4",
    "howler": "2.2.4",
    "js-confetti": "0.12.0",
    "motion": "12.23.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "3.2.1",
    "react-icons": "5.7.0",
    "react-wrap-balancer": "1.1.0",
    "react-youtube": "10.1.0",
    "uuid": "14.0.1",
    "zustand": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@capacitor/assets": "3.0.5",
    "@capacitor/cli": "8.4.1",
    "@commitlint/cli": "17.7.2",
    "@commitlint/config-conventional": "17.7.0",
    "autoprefixer": "10.4.16",
    "commitizen": "4.3.0",
    "cz-conventional-changelog": "3.3.0",
    "husky": "8.0.3",
    "lint-staged": "14.0.1",
    "postcss-nesting": "12.0.1",
    "standard-version": "9.5.0",
    "typescript": "5.9.3",
    "vite-plugin-pwa": "1.3.0",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1"
  }
}
